# =============================================================================
# Mars Face Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# Supabase (Backend + Auth)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:3001
BACKEND_PORT=3001
NODE_ENV=development

# JWT signing secret for API authentication
API_JWT_SECRET=your-api-jwt-secret

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# -----------------------------------------------------------------------------
# Dashboard (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Mobile (React Native / Expo)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
EXPO_PUBLIC_API_URL=http://localhost:3001

# EAS Build
EXPO_PROJECT_ID=your-expo-project-id

# Firebase Cloud Messaging (Push Notifications)
FCM_SERVER_KEY=your-fcm-server-key
FCM_SENDER_ID=your-fcm-sender-id

# -----------------------------------------------------------------------------
# n8n Automation
# -----------------------------------------------------------------------------
N8N_INSTANCE_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your-n8n-api-key

# TradingView webhook passphrase
TRADINGVIEW_WEBHOOK_SECRET=your-tradingview-webhook-secret

# -----------------------------------------------------------------------------
# Trading APIs
# -----------------------------------------------------------------------------

# MetaTrader 5
MT5_SERVER=your-mt5-broker-server
MT5_LOGIN=your-mt5-login
MT5_PASSWORD=your-mt5-password

# Alpaca (US equities)
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# -----------------------------------------------------------------------------
# AI Services
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...your-openai-key
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------

# Sentry (error tracking)
SENTRY_DSN=https://your-sentry-dsn

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Device Management (MDM)
# -----------------------------------------------------------------------------
ESPER_API_KEY=your-esper-api-key
ESPER_ENTERPRISE_ID=your-esper-enterprise-id
